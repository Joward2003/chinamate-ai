# Server-only DeepSeek official API configuration.
# Never prefix this key with NEXT_PUBLIC_.
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# deepseek_v4_flash | deepseek_v4_pro
LLM_MODEL=deepseek_v4_flash
LLM_TIMEOUT_MS=30000
LLM_FALLBACK_MODELS=deepseek_v4_flash,deepseek_v4_pro
